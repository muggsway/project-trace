# Anthropic (Claude) — Person A & B
ANTHROPIC_API_KEY=

# ElevenLabs STT — Person A (Voice & Parsing)
ELEVENLABS_API_KEY=

# Neon (Postgres) — Person C & D (Data & Infrastructure)
DATABASE_URL=

# Garmin Connect — used by scripts/garmin_sync.py
# Your standard Garmin Connect login (no developer account needed)
# First run will create a token cache at ~/.garminconnect so you won't need to re-login
GARMIN_EMAIL=
GARMIN_PASSWORD=

# Twilio (WhatsApp) — outbound daily summary only
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+91XXXXXXXXXX

# Ara — bidirectional WhatsApp agent (inbound + replies)
# Get ARA_API_KEY from app.ara.so → Settings → System → API Key
# After `ara deploy scripts/ara_agent.py`, set ARA_RUNTIME_KEY to the returned value
ARA_API_KEY=
ARA_RUNTIME_KEY=
